# ── Anthropic (Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Alpha Vantage (live market data) ──────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Free tier: 25 API requests/day, 5 calls/min.
# Get a key at https://www.alphavantage.co/support/#api-key

# ── SEC EDGAR (no auth required, but User-Agent is mandatory per SEC policy)
# Format must be: "Your Name your@email.com"
EDGAR_USER_AGENT="Your Name your@email.com"

# ── Application paths ─────────────────────────────────────────────────────
FILINGS_DIR=data/filings
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=sec_10k_chunks

# ── Claude model ──────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── Chunking parameters ───────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# ── RAG retrieval ─────────────────────────────────────────────────────────
RETRIEVER_K=6
RETRIEVER_FETCH_K=20

# ── Alpha Vantage in-session cache TTL (seconds) ──────────────────────────
MARKET_DATA_CACHE_TTL=60
